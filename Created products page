<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Our Products - Chartcart</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Roboto', sans-serif; }
        body { background-color: #f1f3f6; }

        /* Navigation Bar (Same as your screenshot) */
        .navbar {
            background-color: #212121;
            padding: 10px;
            display: flex;
            justify-content: center;
            gap: 10px;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .nav-btn {
            background: #333;
            color: white;
            padding: 8px 20px;
            border-radius: 5px;
            text-decoration: none;
            font-size: 14px;
        }
        .nav-btn.active { background-color: #2ecc71; }

        /* Product Grid */
        .container {
            max-width: 1200px;
            margin: 20px auto;
            padding: 0 10px;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
            gap: 15px;
        }

        /* Flipkart Style Card */
        .card {
            background: white;
            border-radius: 4px;
            padding: 15px;
            transition: box-shadow 0.3s;
            border: 1px solid #e0e0e0;
            display: flex;
            flex-direction: column;
        }
        .card:hover { box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
        
        .img-container {
            height: 180px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 10px;
        }
        .img-container img { max-width: 100%; max-height: 100%; object-fit: contain; }

        .title {
            font-size: 14px;
            color: #212121;
            height: 40px;
            overflow: hidden;
            margin-bottom: 5px;
            font-weight: 500;
        }
        .rating {
            background: #388e3c;
            color: white;
            font-size: 12px;
            padding: 2px 6px;
            border-radius: 3px;
            width: fit-content;
            margin-bottom: 10px;
        }
        .price-box { margin-top: auto; }
        .price { font-size: 18px; font-weight: 700; color: #212121; }
        .old-price { text-decoration: line-through; color: #878787; font-size: 14px; margin-left: 5px; }
        .off { color: #388e3c; font-size: 13px; font-weight: 700; margin-left: 5px; }

        .buy-btn {
            width: 100%;
            background: #fb641b;
            color: white;
            border: none;
            padding: 10px;
            margin-top: 15px;
            font-weight: bold;
            border-radius: 2px;
            cursor: pointer;
        }
    </style>
</head>
<body>

    <div class="navbar">
        <a href="index.html" class="nav-btn">Home</a>
        <a href="products.html" class="nav-btn active">Products</a>
        <a href="#" class="nav-btn">Cart</a>
        <a href="contact.html" class="nav-btn">Contact</a>
    </div>

    <div class="container">
        <div class="card">
            <div class="img-container">
                <img src="https://via.placeholder.com/200x200?text=Product+1" alt="Product">
            </div>
            <div class="title">Samsung Galaxy M34 5G (Prism Silver, 128 GB)</div>
            <div class="rating">4.3 ★</div>
            <div class="price-box">
                <span class="price">₹15,999</span>
                <span class="old-price">₹24,499</span>
                <span class="off">34% off</span>
            </div>
            <button class="buy-btn">BUY NOW</button>
        </div>

        <div class="card">
            <div class="img-container">
                <img src="https://via.placeholder.com/200x200?text=Product+2" alt="Product">
            </div>
            <div class="title">BoAt Airdopes 131 with 60 Hours Playback</div>
            <div class="rating">4.1 ★</div>
            <div class="price-box">
                <span class="price">₹999</span>
                <span class="old-price">₹2,990</span>
                <span class="off">66% off</span>
            </div>
            <button class="buy-btn">BUY NOW</button>
        </div>

        </div>

</body>
</html>
